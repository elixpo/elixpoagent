# ===========================================
# Elixpo — Environment Variables
# Copy to .env and fill in your values
# ===========================================

# --- LLM Provider (legacy fallback) ---
ELIXPO_LLM_API_URL=https://api.moonshot.cn/v1
ELIXPO_LLM_API_KEY=sk-your-key-here
ELIXPO_LLM_MODEL=kimi
ELIXPO_LLM_MAX_CONTEXT_TOKENS=128000
ELIXPO_LLM_TEMPERATURE=0.0

# --- Kimi (primary model for tool calls) ---
ELIXPO_KIMI_API_URL=https://api.moonshot.cn/v1
ELIXPO_KIMI_API_KEY=sk-your-kimi-key
ELIXPO_KIMI_MODEL=moonshot-v1-128k
ELIXPO_KIMI_MAX_CONTEXT_TOKENS=128000

# --- Perplexity (web search / research) ---
ELIXPO_PERPLEXITY_API_URL=https://api.perplexity.ai
ELIXPO_PERPLEXITY_API_KEY=pplx-your-key-here
ELIXPO_PERPLEXITY_MODEL=sonar
ELIXPO_PERPLEXITY_MAX_CONTEXT_TOKENS=128000

# --- GitHub App ---
ELIXPO_GITHUB_APP_ID=
ELIXPO_GITHUB_PRIVATE_KEY_PATH=./secrets/github-app.pem
ELIXPO_GITHUB_WEBHOOK_SECRET=
ELIXPO_GITHUB_BOT_USERNAME=elixpoo

# --- Agent ---
ELIXPO_MAX_AGENT_STEPS=50
ELIXPO_MAX_TOKENS_PER_SESSION=500000
ELIXPO_MAX_CONCURRENT_SESSIONS=5
ELIXPO_SESSION_STORAGE_PATH=/data/sessions
ELIXPO_WORKSPACE_PATH=/data/workspaces
ELIXPO_DEFAULT_REASONING_EFFORT=medium

# --- Sandbox ---
ELIXPO_SANDBOX_MODE=none
ELIXPO_SANDBOX_TIMEOUT=120
ELIXPO_SANDBOX_MEMORY_LIMIT=512M

# --- Cloudflare ---
ELIXPO_CF_ACCOUNT_ID=b3646c532659b14184b252f312f74ef3
ELIXPO_CF_D1_DATABASE_ID=4c028188-932f-4808-81ba-67e67a832be7
ELIXPO_CF_KV_NAMESPACE_ID=8e440b0aebbe4961a655915469da98df
ELIXPO_CF_API_TOKEN=

# --- Server ---
ELIXPO_API_SECRET_KEY=change-me-in-production
ELIXPO_CORS_ORIGINS=["http://localhost:3000"]
ELIXPO_DEBUG=true

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
