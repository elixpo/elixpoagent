# ===========================================
# Panda — Environment Variables
# Copy to .env and fill in your values
# ===========================================

# --- LLM Provider (OpenAI-compatible) ---
PANDA_LLM_API_URL=https://api.openai.com/v1
PANDA_LLM_API_KEY=sk-your-key-here
PANDA_LLM_MODEL=gpt-4o
PANDA_LLM_MAX_CONTEXT_TOKENS=128000
PANDA_LLM_TEMPERATURE=0.0

# --- GitHub App ---
PANDA_GITHUB_APP_ID=
PANDA_GITHUB_PRIVATE_KEY_PATH=./secrets/github-app.pem
PANDA_GITHUB_WEBHOOK_SECRET=
PANDA_GITHUB_BOT_USERNAME=elixpoo

# --- Agent ---
PANDA_MAX_AGENT_STEPS=50
PANDA_MAX_TOKENS_PER_SESSION=500000
PANDA_MAX_CONCURRENT_SESSIONS=5
PANDA_SESSION_STORAGE_PATH=/data/sessions
PANDA_WORKSPACE_PATH=/data/workspaces

# --- Sandbox ---
PANDA_SANDBOX_MODE=none
PANDA_SANDBOX_TIMEOUT=120
PANDA_SANDBOX_MEMORY_LIMIT=512M

# --- Cloudflare ---
PANDA_CF_ACCOUNT_ID=b3646c532659b14184b252f312f74ef3
PANDA_CF_D1_DATABASE_ID=4c028188-932f-4808-81ba-67e67a832be7
PANDA_CF_KV_NAMESPACE_ID=8e440b0aebbe4961a655915469da98df
PANDA_CF_API_TOKEN=

# --- Server ---
PANDA_API_SECRET_KEY=change-me-in-production
PANDA_CORS_ORIGINS=["http://localhost:3000"]
PANDA_DEBUG=true

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
